# Copy this file to .env.development and fill in your local values
# For Docker Compose, copy to .env

# Environment
APP_ENV=development

# Database Configurations
DB_ROOT_PASSWORD=rootpassword
DB_HOST=mysql
DB_PORT=3306
DB_USER=gowallet_user
DB_PASSWORD=gowallet_password
DB_NAME=gowallet
DB_NAME_DEFAULT=gowallet
DB_NAME_AUTH=gowallet_auth
DB_NAME_USER=gowallet_user
DB_NAME_WALLET=gowallet_wallet
DB_NAME_LEDGER=gowallet_ledger
DB_NAME_TRANSACTION=gowallet_transaction

# Redis Configurations
REDIS_HOST=redis
REDIS_PORT=6379

# Message Broker Configurations
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_MGMT_PORT=15672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest

# MongoDB Configurations (audit-service)
MONGO_URL=mongodb://mongodb:27017
MONGO_PORT=27017

# SMTP / Email Configurations
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_FROM=no-reply@gowallet.com

# MinIO Configuration (Object Storage)
MINIO_PORT=9000
MINIO_WEB_PORT=9001
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_PUBLIC_URL=http://localhost:9000
OUTBOX_ARCHIVE_AGE=24h

# Service Ports
GATEWAY_PORT=8080
AUTH_PORT=8081
WALLET_PORT=8082
PAYMENT_PORT=8083
USER_PORT=8084
LEDGER_PORT=8085
TRANSACTION_PORT=8086
MAILHOG_PORT=1025
MAILHOG_WEB_PORT=8025

# gRPC Ports
AUTH_GRPC_PORT=50051
WALLET_GRPC_PORT=50053
LEDGER_GRPC_PORT=50054
TRANSACTION_GRPC_PORT=50055
PAYMENT_GRPC_PORT=50056

# gRPC Addresses
AUTH_GRPC_ADDR=auth-service:50051
USER_GRPC_ADDR=user-service:50052
WALLET_GRPC_ADDR=wallet-service:50053
LEDGER_GRPC_ADDR=ledger-service:50054
TRANSACTION_GRPC_ADDR=transaction-service:50055
PAYMENT_GRPC_ADDR=payment-service:50056

# JWT Configuration (MUST be at least 32 characters in production)
JWT_SECRET=your-super-secret-jwt-key-at-least-32-characters

# Google OAuth Configuration
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your-google-client-secret
GOOGLE_REDIRECT_URL=http://localhost:8080/api/v1/auth/google/callback

# Service URLs for API Gateway
AUTH_SERVICE_URL=http://auth-service:8081
USER_SERVICE_URL=http://user-service:8084
WALLET_SERVICE_URL=http://wallet-service:8082
LEDGER_SERVICE_URL=http://ledger-service:8085
TRANSACTION_SERVICE_URL=http://transaction-service:8086
PAYMENT_SERVICE_URL=http://payment-service:8083

TRANSACTION_BASE_URL=http://localhost:8086

# Stripe Sandbox Configuration
STRIPE_SECRET_KEY=sk_test_your_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Base URL for redirect callbacks (Stripe success/cancel URLs)
BASE_URL=http://localhost:8080

MONOLITH_BASE_URL=http://host.docker.internal:8000
WEBHOOK_SECRET=gowallet-webhook-secret-change-me
GATEWAY_CALLBACK_URL=http://host.docker.internal:8080
